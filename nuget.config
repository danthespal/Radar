<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!--
      For local development: run Sdk/build-sdk.ps1 from the OriathHub repo to populate the local feed.
      Two paths are provided so this works both while the plugin is inside the OriathHub tree
      and after it has been cloned as a sibling folder. NuGet silently skips paths that don't exist.
    -->
    <add key="OriathHub-local-inrepo" value="../../Sdk/local-nuget/" />
    <add key="OriathHub-local-sibling" value="../OriathHub/Sdk/local-nuget/" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
