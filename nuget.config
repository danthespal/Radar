<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!--
      The OriathHub.Sdk package ships alongside the plugin source in SDK/local-nuget/.
      Commit OriathHub.Sdk.<version>.nupkg into that folder so anyone who clones this
      repo (or the Plugins Marketplace) can build without any external setup.
      nuget.org is re-added after the clear so other PackageReferences still resolve.
    -->
    <add key="oriathhub-sdk" value="SDK/local-nuget" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
